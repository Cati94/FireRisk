# FireRisk environment example
# Never put real keys in this file.

# App
PORT=5173
FIRERISK_ENABLE_MOCKS=true
FIRERISK_PROVIDER_TIMEOUT_MS=8000
FIRERISK_CACHE_TTL_SECONDS=300
FIRERISK_LOG_LEVEL=info
FIRERISK_FORCE_DEGRADED=false

# Map tiles / styles
MAPTILER_KEY=
MAPTILER_STYLE_URL=

# NASA FIRMS
FIRMS_MAP_KEY=
FIRMS_BASE_URL=https://firms.modaps.eosdis.nasa.gov/api

# ICNF / occurrences
ICNF_OCCURRENCES_URL=https://fogos.icnf.pt/localizador/webserviceocorrencias.asp

# Flightradar24 / aircraft
FLIGHTRADAR24_API_KEY=
FLIGHTRADAR24_BASE_URL=

# Weather Underground / PWS / The Weather Company
WEATHER_UNDERGROUND_API_KEY=
WEATHER_UNDERGROUND_STATION_IDS=
WEATHER_UNDERGROUND_BASE_URL=

# Vaisala Xweather
XWEATHER_CLIENT_ID=
XWEATHER_CLIENT_SECRET=
XWEATHER_BASE_URL=

# FireRisk AI
FIRERISK_AI_MODE=mock
FIRERISK_AI_LOCAL_ENDPOINT=
FIRERISK_AI_REMOTE_ENDPOINT=
FIRERISK_AI_API_KEY=
